{
  "name": "yijianzhichuang",
  "version": 1,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/$1"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ],
  "env": {
    "NODE_VERSION": "18"
  }
}
